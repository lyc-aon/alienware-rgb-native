#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import subprocess
import sys
import tempfile
import time
from pathlib import Path
from typing import Any, Callable


ROOT = Path(__file__).resolve().parent.parent
BROKER = ROOT / "scripts" / "rgb-event-broker"


def write_json(path: Path, obj: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(obj, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def read_json(path: Path) -> dict[str, Any]:
    try:
        with path.open("r", encoding="utf-8") as f:
            value = json.load(f)
    except Exception:
        return {}
    return value if isinstance(value, dict) else {}


def wait_until(label: str, fn: Callable[[], bool], timeout: float = 5.0) -> None:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if fn():
            return
        time.sleep(0.05)
    raise AssertionError(f"timed out waiting for {label}")


def send_event(fifo: Path, event_id: str, session: str = "test-session") -> None:
    req = {
        "event_id": event_id,
        "session": session,
        "cwd": str(ROOT),
        "project_dir": str(ROOT),
        "pwd": str(ROOT),
        "force": True,
        "throttle_sec": 0,
        "caller_pid": 0,
        "client_pid": os.getpid(),
    }
    with fifo.open("w", encoding="utf-8") as f:
        f.write(json.dumps(req) + "\n")


def recent_has(status_path: Path, event_id: str, result: str) -> bool:
    recent = read_json(status_path).get("recent", [])
    return any(item.get("event") == event_id and item.get("result") == result for item in recent if isinstance(item, dict))


def main() -> int:
    with tempfile.TemporaryDirectory(prefix="alienware-rgb-broker-test.") as tmp_raw:
        tmp = Path(tmp_raw)
        config_dir = tmp / "config"
        runtime_dir = tmp / "run"
        voice_dir = tmp / "voice-cache"
        runtime_dir.mkdir(parents=True)
        voice_dir.mkdir(parents=True)
        (voice_dir / "unit-fire.wav").write_bytes(b"RIFF")

        write_json(config_dir / "voice.json", {
            "enabled": False,
            "output_dir": str(voice_dir),
            "phrases": {"unit-fire": "unit test"},
        })
        write_json(config_dir / "runtime_events.json", {
            "version": 1,
            "max_queue": 4,
            "global_cooldown_sec": {"critical": 0, "normal": 0, "low": 0},
            "disabled_events": ["disabled-*"],
            "events": {
                "unit-fire": {
                    "effect": "pulse",
                    "duration": 1,
                    "priority": "normal",
                    "throttle": 0,
                    "force": True,
                    "voice": False,
                    "zones": "all",
                    "rgb": [1, 2, 3],
                },
                "unit-runtime-disabled": {
                    "effect": "pulse",
                    "duration": 1,
                    "priority": "normal",
                    "throttle": 0,
                    "force": True,
                    "voice": False,
                    "zones": "all",
                    "rgb": [4, 5, 6],
                },
            },
        })

        env = os.environ.copy()
        env.update({
            "ALIENWARE_RGB_CONFIG_DIR": str(config_dir),
            "XDG_RUNTIME_DIR": str(runtime_dir),
            "RGB_BROKER_DRY_RUN": "1",
            "RGB_BROKER_CLI": "/bin/true",
            "RGB_BROKER_STATUS_HEARTBEAT_SEC": "0.2",
            "PYTHONUNBUFFERED": "1",
        })

        fifo = runtime_dir / "rgb-event-broker.fifo"
        status_path = runtime_dir / "rgb-event-broker.status.json"
        proc = subprocess.Popen(
            [sys.executable, str(BROKER)],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            env=env,
        )
        try:
            wait_until("broker fifo", fifo.is_fifo)
            wait_until("broker status", lambda: read_json(status_path).get("pid") == proc.pid)
            status = read_json(status_path)
            if status.get("runtime_disabled") is not False:
                raise AssertionError(f"expected runtime_disabled false at startup: {status}")
            first_seq = int(status.get("status_seq", 0))
            if first_seq < 1:
                raise AssertionError(f"expected positive status_seq at startup: {status}")
            if abs(float(status.get("heartbeat_sec", 0)) - 0.2) > 0.001:
                raise AssertionError(f"expected heartbeat_sec 0.2: {status}")
            wait_until("broker heartbeat", lambda: int(read_json(status_path).get("status_seq", 0)) > first_seq)

            doctor = subprocess.run(
                [sys.executable, str(BROKER), "doctor"],
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                timeout=3,
                check=False,
                env=env,
            )
            if doctor.returncode != 0:
                raise AssertionError(f"broker doctor failed:\nstdout={doctor.stdout}\nstderr={doctor.stderr}")

            send_event(fifo, "unit-fire")
            wait_until("unit-fire fired", lambda: recent_has(status_path, "unit-fire", "fired"))
            if read_json(status_path).get("fired", 0) < 1:
                raise AssertionError("broker did not increment fired count")

            send_event(fifo, "disabled-case")
            wait_until("disabled pattern drop", lambda: recent_has(status_path, "disabled-case", "drop-disabled"))

            send_event(fifo, "unknown-event")
            wait_until("unknown event drop", lambda: recent_has(status_path, "unknown-event", "drop-unknown"))

            (config_dir / "runtime-disabled").write_text("disabled by broker test\n", encoding="utf-8")
            send_event(fifo, "unit-runtime-disabled")
            wait_until(
                "runtime-disabled drop",
                lambda: recent_has(status_path, "unit-runtime-disabled", "drop-runtime-disabled"),
            )
            status = read_json(status_path)
            if status.get("runtime_disabled") is not True:
                raise AssertionError(f"expected runtime_disabled true after marker: {status}")

            print("runtime broker tests: passed")
            return 0
        finally:
            proc.terminate()
            try:
                proc.wait(timeout=3)
            except subprocess.TimeoutExpired:
                proc.kill()
                proc.wait(timeout=3)
            if proc.returncode not in (0, -15, -2):
                stdout, stderr = proc.communicate(timeout=1)
                raise AssertionError(f"broker exited {proc.returncode}\nstdout={stdout}\nstderr={stderr}")


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as exc:
        print(f"runtime broker tests failed: {exc}", file=sys.stderr)
        raise SystemExit(1)
